# ============================================================
# CLINOVA — ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your values
# ============================================================

# ── Database (NeonDB / PostgreSQL) ──────────────────────────
DATABASE_URL=postgresql://user:password@host/clinova?sslmode=require

# ── JWT Auth ────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Gateway Service ──────────────────────────────────────────
GATEWAY_PORT=3000

# ── AI Service ───────────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8001
AI_SERVICE_PORT=8001

# ── FHIR Service ─────────────────────────────────────────────
FHIR_SERVICE_URL=http://fhir-service:8002
FHIR_SERVICE_PORT=8002

# ── Voice Service ─────────────────────────────────────────────
VOICE_SERVICE_URL=http://voice-service:8003
VOICE_SERVICE_PORT=8003

# ── Audit Service ─────────────────────────────────────────────
AUDIT_SERVICE_URL=http://audit-service:8004
AUDIT_SERVICE_PORT=8004

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
FRONTEND_PORT=3001

# ── Mistral AI ────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-medium-latest

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8005
CHROMA_COLLECTION_PATIENTS=patient_notes
CHROMA_COLLECTION_GUIDELINES=clinical_guidelines
CHROMA_COLLECTION_AI_MEMORY=ai_memory

# ── Kafka (Upstash) ───────────────────────────────────────────
KAFKA_BROKER_URL=your_upstash_kafka_broker_url
KAFKA_USERNAME=your_upstash_kafka_username
KAFKA_PASSWORD=your_upstash_kafka_password
KAFKA_CLIENT_ID=clinova-gateway

# ── LiveKit ───────────────────────────────────────────────────
LIVEKIT_URL=wss://your-livekit-cloud-url
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Deepgram ──────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── Cartesia ──────────────────────────────────────────────────
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_VOICE_ID=your_cartesia_voice_id

# ── Security ──────────────────────────────────────────────────
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here
TLS_ENABLED=true
SESSION_TIMEOUT_MINUTES=30

# ── Compliance ────────────────────────────────────────────────
DPDP_INDIA_REGION=false
HIPAA_MODE=true
AUDIT_RETENTION_DAYS=2555
